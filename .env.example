# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL connection string
DATABASE_URL="postgresql://inmarco:your-secure-password@localhost:5432/inmarco_website?schema=public"

# PostgreSQL Password (for Docker Compose)
POSTGRES_PASSWORD=your-secure-password

# ============================================
# ADMIN AUTHENTICATION
# ============================================

# Admin user credentials for database seeding
# IMPORTANT: Set these before running 'npx prisma db seed'
# If not set, a random password will be generated
ADMIN_USERNAME="Inmarco"
ADMIN_EMAIL="admin@inmarco.ae"
ADMIN_PASSWORD="your-secure-password-here"

# JWT Secret (generate a strong random string for production)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ============================================
# EMAIL CONFIGURATION (Microsoft Graph API)
# ============================================

AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_EMAIL_FROM=noreply@inmarco.ae

# ============================================
# ANALYTICS
# ============================================

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager (Optional - for advanced tracking)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Microsoft Clarity (Optional - Free heatmaps and session recordings)
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# Google Search Console Verification Code
NEXT_PUBLIC_GSC_VERIFICATION=your-verification-code-here

# ============================================
# APPLICATION SETTINGS
# ============================================

NODE_ENV=production
PORT=3000
NEXT_TELEMETRY_DISABLED=1
