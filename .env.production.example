# Production Environment Variables
# Copy this to .env on your server and fill in the values

# Database
DATABASE_URL="postgresql://username:password@your-db-host:5432/inmarco_website"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://yourdomain.com"

# Optional: If using external services
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="ap-south-1"
